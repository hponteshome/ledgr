{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",          // Essencial para "type": "module"
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "./dist",
    "declaration": true,
    "isolatedModules": true,
    "strict": true,
    "noImplicitAny": false,        // Facilita a migração do monólito
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/*/src"],
      "@ledgr/prisma": ["infra/prisma"]
    }
  },
  "include": [
    "infra/prisma/**/*.ts", 
    "apps/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
