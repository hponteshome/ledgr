version: '3.8'

services:
  postgres:
    image: postgres:16-alpine
    container_name: ledgr-postgres
    environment:
      POSTGRES_USER: ledgr
      POSTGRES_PASSWORD: ledgr123
      POSTGRES_DB: ledgr
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    container_name: ledgr-redis
    ports:
      - "6379:6379"
    restart: unless-stopped

volumes:
  postgres-data: