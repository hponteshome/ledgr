// =============================================================================
// 11 · IMPORTAÇÃO BANCÁRIA
// =============================================================================

enum BankImportStatus {
  PENDING
  CLASSIFIED
  POSTED
  IGNORED
  RECONCILED
}

enum BankCode {
  ITAU
  BRADESCO
  BB
  SANTANDER
  CAIXA
  SICREDI
  SICOOB
  NUBANK
  INTER
  GENERIC
}

enum TransactionType {
  DEBIT
  CREDIT
}

/// Extratos bancários importados. Agrupa transações de um período.
model BankStatement {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  bankCode       BankCode  @map("bank_code")
  bankName       String    @map("bank_name") @db.VarChar
  agency         String?   @map("agency") @db.VarChar
  account        String?   @map("account") @db.VarChar
  periodFrom     DateTime  @map("period_from") @db.Timestamp(6)
  periodTo       DateTime  @map("period_to") @db.Timestamp(6)
  fileName       String    @map("file_name") @db.VarChar
  fileFormat     String    @map("file_format") @db.VarChar
  totalLines     Int       @map("total_lines")
  totalDebits    Decimal   @map("total_debits") @db.Decimal(15, 2)
  totalCredits   Decimal   @map("total_credits") @db.Decimal(15, 2)
  openingBalance Decimal?  @map("opening_balance") @db.Decimal(15, 2)
  closingBalance Decimal?  @map("closing_balance") @db.Decimal(15, 2)
  createdById    String    @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(6)

  transactions BankTransaction[]

  @@index([companyId, periodFrom])
  @@index([companyId, bankCode])
  @@map("bank_statements")
}

/// Transações individuais de extratos bancários.
/// Motor de sugestão de conta contábil em 3 camadas: regras, ML e histórico.
model BankTransaction {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String           @map("company_id") @db.Uuid
  statementId          String           @map("statement_id") @db.Uuid
  transactionDate      DateTime         @map("transaction_date") @db.Timestamp(6)
  description          String           @map("description") @db.VarChar
  descriptionNorm      String           @map("description_norm") @db.VarChar
  amount               Decimal          @map("amount") @db.Decimal(15, 2)
  type                 TransactionType  @map("type")
  balance              Decimal?         @map("balance") @db.Decimal(15, 2)
  bankRef              String?          @map("bank_ref") @db.VarChar
  agency               String?          @map("agency") @db.VarChar
  groupKey             String?          @map("group_key") @db.VarChar
  status               BankImportStatus @default(PENDING) @map("status")
  accountId            String?          @map("account_id") @db.Uuid
  counterAccountId     String?          @map("counter_account_id") @db.Uuid
  memo                 String?          @map("memo") @db.VarChar
  costCenter           String?          @map("cost_center") @db.VarChar
  suggestedAccountId   String?          @map("suggested_account_id") @db.Uuid
  suggestionSource     String?          @map("suggestion_source") @db.VarChar
  suggestionConfidence Int?             @map("suggestion_confidence")
  apEntryId            String?          @map("ap_entry_id") @db.Uuid
  arEntryId            String?          @map("ar_entry_id") @db.Uuid
  payrollId            String?          @map("payroll_id") @db.Uuid
  journalEntryId       String?          @map("journal_entry_id") @db.Uuid
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  statement BankStatement @relation(fields: [statementId], references: [id])

  @@index([companyId, transactionDate])
  @@index([statementId])
  @@index([status])
  @@index([descriptionNorm])
  @@index([groupKey])
  @@map("bank_transactions")
}

/// Regras de classificação automática para importação bancária.
/// Motor de aprendizado: usageCount aumenta a cada aplicação.
model BankImportRule {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String           @map("company_id") @db.Uuid
  textPattern  String           @map("text_pattern") @db.VarChar
  bankCode     BankCode?        @map("bank_code")
  type         TransactionType? @map("type")
  accountId    String           @map("account_id") @db.Uuid
  memoTemplate String?          @map("memo_template") @db.VarChar
  isFixed      Boolean          @default(false) @map("is_fixed")
  usageCount   Int              @default(0) @map("usage_count")
  lastUsedAt   DateTime?        @map("last_used_at") @db.Timestamp(6)
  createdById  String           @map("created_by_id") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt    DateTime?        @map("deleted_at") @db.Timestamp(6)

  @@unique([companyId, textPattern, bankCode, type])
  @@index([companyId, usageCount])
  @@map("bank_import_rules")
}

// =============================================================================
// 12 · LIVROS SOCIETÁRIOS — REGISTRO E TRANSFERÊNCIA
// =============================================================================

enum ShareType {
  ORDINARIA    /// ON — direito a voto
  PREFERENCIAL /// PN — sem voto, preferência em dividendos
  QUOTA        /// Ltda — quota social

  @@map("share_type")
}

enum ShareEntryType {
  SA    /// Sociedade Anônima — usa ações
  LTDA  /// Limitada — usa quotas

  @@map("share_entry_type")
}

enum TransferReason {
  COMPRA_VENDA     /// Cessão onerosa entre partes
  DOACAO           /// Transmissão gratuita
  HERANCA          /// Sucessão causa mortis
  INTEGRALIZACAO   /// Integralização de capital
  REDUCAO_CAPITAL  /// Redução de capital com devolução
  BONIFICACAO      /// Emissão por incorporação de reservas
  CISAO            /// Cisão total ou parcial
  INCORPORACAO     /// Absorção por outra sociedade
  OUTRO

  @@map("transfer_reason")
}

/// Registro de acionistas/quotistas (Livro de Registro de Ações/Quotas).
/// Mantém o saldo atual de cada titular por série/tipo de ação.
/// Base legal: Lei 6.404/76 art. 31 (S/A) e CC art. 1.053 (Ltda).
model ShareholderRecord {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String         @map("company_id") @db.Uuid
  bookId       String?        @map("book_id") @db.Uuid          /// vínculo com CorporateBook
  entryType    ShareEntryType @map("entry_type")                /// SA ou LTDA

  // ── Titular ───────────────────────────────────────────────
  holderName   String         @map("holder_name") @db.VarChar
  holderTaxId  String         @map("holder_tax_id") @db.VarChar(18)  /// CPF ou CNPJ
  holderType   String         @default("PF") @map("holder_type") @db.VarChar(2) /// PF | PJ
  personId     String?        @map("person_id") @db.Uuid        /// vínculo opcional com Person
  address      String?        @map("address") @db.VarChar

  // ── Participação ──────────────────────────────────────────
  shareType    ShareType      @map("share_type")
  series       String?        @map("series") @db.VarChar(10)    /// série (ex: "A", "B")
  quantity     Decimal        @map("quantity") @db.Decimal(18, 6)
  nominalValue Decimal        @map("nominal_value") @db.Decimal(15, 2)  /// valor nominal por ação/quota
  totalValue   Decimal        @map("total_value") @db.Decimal(18, 2)    /// qty × nominalValue
  percentOwned Decimal        @map("percent_owned") @db.Decimal(8, 4)   /// % do capital

  // ── Integralização ────────────────────────────────────────
  subscriptionDate   DateTime? @map("subscription_date") @db.Date
  integralizationDate DateTime? @map("integralization_date") @db.Date
  paidInAmount       Decimal   @default(0) @map("paid_in_amount") @db.Decimal(18, 2)
  isFullyPaid        Boolean   @default(false) @map("is_fully_paid")

  // ── Restrições / Gravames ─────────────────────────────────
  hasEncumbrance  Boolean   @default(false) @map("has_encumbrance")
  encumbranceDesc String?   @map("encumbrance_desc") @db.Text
  isPledged       Boolean   @default(false) @map("is_pledged")

  // ── Numeração ─────────────────────────────────────────────
  shareNumberFrom  Int?     @map("share_number_from")     /// nº inicial do certificado
  shareNumberTo    Int?     @map("share_number_to")       /// nº final do certificado
  certificateNumber String? @map("certificate_number") @db.VarChar(30)

  // ── Controle ──────────────────────────────────────────────
  isActive    Boolean   @default(true) @map("is_active")
  notes       String?   @map("notes") @db.Text
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)

  // ── Relations ─────────────────────────────────────────────
  company          Company          @relation(fields: [companyId], references: [id])
  person           Person?          @relation(fields: [personId], references: [id])
  transfersAsFrom  ShareTransfer[]  @relation("TransferFrom")
  transfersAsTo    ShareTransfer[]  @relation("TransferTo")

  @@index([companyId, isActive])
  @@index([companyId, holderTaxId])
  @@index([companyId, shareType])
  @@map("shareholder_records")
}

/// Transferências de ações/quotas (Livro de Transferência).
/// Cada transferência é imutável após registrada (append-only).
/// Base legal: Lei 6.404/76 art. 36 (S/A) e CC art. 1.057 (Ltda).
model ShareTransfer {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String         @map("company_id") @db.Uuid
  bookId      String?        @map("book_id") @db.Uuid
  entryType   ShareEntryType @map("entry_type")

  // ── Partes ────────────────────────────────────────────────
  fromRecordId String  @map("from_record_id") @db.Uuid   /// ShareholderRecord do cedente
  toRecordId   String  @map("to_record_id") @db.Uuid     /// ShareholderRecord do cessionário

  // ── Objeto da transferência ───────────────────────────────
  shareType      ShareType      @map("share_type")
  series         String?        @map("series") @db.VarChar(10)
  quantity       Decimal        @map("quantity") @db.Decimal(18, 6)
  nominalValue   Decimal        @map("nominal_value") @db.Decimal(15, 2)
  transferValue  Decimal        @map("transfer_value") @db.Decimal(18, 2)  /// preço efetivo da cessão
  shareNumberFrom Int?          @map("share_number_from")
  shareNumberTo   Int?          @map("share_number_to")

  // ── Dados do ato ──────────────────────────────────────────
  transferDate   DateTime       @map("transfer_date") @db.Date
  reason         TransferReason @map("reason")
  instrumentType String?        @map("instrument_type") @db.VarChar(100) /// "Contrato de Cessão", "Escritura", etc.
  instrumentDate DateTime?      @map("instrument_date") @db.Date
  notaryOffice   String?        @map("notary_office") @db.VarChar(255)   /// Cartório (se escriturado)
  bookNumber     String?        @map("book_number_notary") @db.VarChar(30)
  pageNumber     String?        @map("page_number") @db.VarChar(10)

  // ── Averbação no livro ────────────────────────────────────
  averbacaoDate    DateTime?   @map("averbacao_date") @db.Date
  averbacaoUserId  String?     @map("averbacao_user_id") @db.Uuid

  // ── Documento gerado ──────────────────────────────────────
  documentId  String?   @map("document_id") @db.Uuid

  notes       String?   @map("notes") @db.Text
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // ── Relations ─────────────────────────────────────────────
  company     Company            @relation(fields: [companyId], references: [id])
  fromRecord  ShareholderRecord  @relation("TransferFrom", fields: [fromRecordId], references: [id])
  toRecord    ShareholderRecord  @relation("TransferTo", fields: [toRecordId], references: [id])

  @@index([companyId, transferDate])
  @@index([fromRecordId])
  @@index([toRecordId])
  @@map("share_transfers")
}
// =============================================================================
// LEDGR — Adição ao schema.prisma
// Módulo: Renda Fixa (CDB / LCI / LCA / CRI / CRA / Debêntures)
// Adicionar após o bloco 10 · ECF
// =============================================================================

enum FixedIncomeType {
  CDB
  LCI
  LCA
  CRI
  CRA
  DEBENTURE
  TESOURO_PREFIXADO
  TESOURO_SELIC
  TESOURO_IPCA
  OUTRO

  @@map("fixed_income_type")
}

enum FixedIncomeIndexer {
  CDI
  SELIC
  IPCA
  IGPM
  PREFIXADO

  @@map("fixed_income_indexer")
}

enum FixedIncomeStatus {
  ATIVO
  RESGATADO
  VENCIDO
  CANCELADO

  @@map("fixed_income_status")
}

enum FixedIncomeEventType {
  APLICACAO
  RESGATE_ANTECIPADO
  RESGATE_VENCIMENTO
  ATUALIZACAO_SALDO    // registro mensal de competência (Lucro Real)
  LANCAMENTO_CONTABIL  // vínculo com JournalEntry

  @@map("fixed_income_event_type")
}

/// Investimentos em renda fixa da empresa (CDB, LCI, LCA, Tesouro...).
/// Suporta múltiplos resgates parciais e antecipados.
/// Para Lucro Real: receita financeira reconhecida mensalmente via eventos ATUALIZACAO_SALDO.
model FixedIncomeInvestment {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String @map("company_id") @db.Uuid

  // ── Identificação ─────────────────────────────────────────
  description   String            @map("description") @db.VarChar(200)
  type          FixedIncomeType   @default(CDB) @map("type")
  issuerName    String            @map("issuer_name") @db.VarChar(100)  // Banco emissor
  issuerCnpj    String?           @map("issuer_cnpj") @db.VarChar(18)
  externalCode  String?           @map("external_code") @db.VarChar(50) // Código na corretora

  // ── Condições financeiras ──────────────────────────────────
  indexer         FixedIncomeIndexer @default(CDI) @map("indexer")
  indexerRate     Decimal            @map("indexer_rate") @db.Decimal(8, 4)   // 96.00 = 96% do CDI
  fixedRate       Decimal?           @map("fixed_rate") @db.Decimal(8, 4)     // Para prefixados
  capitalInitial  Decimal            @map("capital_initial") @db.Decimal(15, 2)
  capitalBalance  Decimal            @map("capital_balance") @db.Decimal(15, 2) // Saldo do principal apos resgates
  capitalCurrent  Decimal            @map("capital_current") @db.Decimal(15, 2) // Saldo bruto total (principal + rendimentos)
  accumulatedYield Decimal           @default(0) @map("accumulated_yield") @db.Decimal(15, 2) // Rendimento bruto acumulado
  totalRedeemed        Decimal       @default(0) @map("total_redeemed") @db.Decimal(15, 2)         // Total liquido resgatado
  totalRedeemedPrincipal Decimal     @default(0) @map("total_redeemed_principal") @db.Decimal(15, 2) // Total principal resgatado

  // ── Datas ─────────────────────────────────────────────────
  applicationDate DateTime  @map("application_date") @db.Date
  maturityDate    DateTime  @map("maturity_date") @db.Date
  lastUpdateDate  DateTime? @map("last_update_date") @db.Date // Última atualização de saldo

  // ── IRRF ──────────────────────────────────────────────────
  irrfExempt      Boolean  @default(false) @map("irrf_exempt")  // LCI/LCA/CRI/CRA são isentos
  accountingAccountId String? @map("accounting_account_id") @db.Uuid  // Conta contabil do investimento
  irrfAccumulated Decimal  @default(0) @map("irrf_accumulated") @db.Decimal(15, 2)

  // ── Contas contábeis ──────────────────────────────────────
  assetAccountId   String? @map("asset_account_id") @db.Uuid   // Ativo: CDB a receber
  revenueAccountId String? @map("revenue_account_id") @db.Uuid  // Receita financeira
  irrfAccountId    String? @map("irrf_account_id") @db.Uuid     // IRRF a recuperar (antecipação)

  status    FixedIncomeStatus @default(ATIVO) @map("status")
  notes     String?           @map("notes") @db.Text
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime?         @map("deleted_at") @db.Timestamp(6)

  company  Company                @relation(fields: [companyId], references: [id])
  events   FixedIncomeEvent[]
  rates    FixedIncomeMonthlyRate[]

  @@index([companyId, status])
  @@index([companyId, maturityDate])
  @@map("fixed_income_investments")
}

/// Taxas CDI/índice mensais reais — histórico para cálculo exato.
model FixedIncomeMonthlyRate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investmentId String   @map("investment_id") @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  competence   String   @map("competence") @db.Char(7)   // "2024-01"
  indexerRate  Decimal  @map("indexer_rate") @db.Decimal(12, 10) // Taxa mensal acumulada (ex: 0.0096669)
  businessDays Int?     @map("business_days")
  calendarDays Int?     @map("calendar_days")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  investment FixedIncomeInvestment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@unique([investmentId, competence])
  @@index([companyId, competence])
  @@map("fixed_income_monthly_rates")
}

/// Eventos do ciclo de vida do investimento.
/// Cada RESGATE_ANTECIPADO reduz capitalCurrent e registra IRRF retido.
model FixedIncomeEvent {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investmentId String               @map("investment_id") @db.Uuid
  companyId    String               @map("company_id") @db.Uuid
  eventType    FixedIncomeEventType @map("event_type")
  eventDate    DateTime             @map("event_date") @db.Date
  competence   String?              @map("competence") @db.Char(7)  // "2024-01" para atualizações

  // ── Valores do evento ─────────────────────────────────────
  grossAmount   Decimal  @default(0) @map("gross_amount") @db.Decimal(15, 2)   // Rendimento bruto do período
  netAmount     Decimal  @default(0) @map("net_amount") @db.Decimal(15, 2)     // Líquido após IRRF
  irrfAmount    Decimal  @default(0) @map("irrf_amount") @db.Decimal(15, 2)    // IRRF retido
  irrfRate      Decimal? @map("irrf_rate") @db.Decimal(5, 4)                   // Alíquota aplicada
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(15, 2)              // Saldo bruto após evento

  // ── Para resgates ─────────────────────────────────────────
  redemptionPrincipal Decimal? @map("redemption_principal") @db.Decimal(15, 2) // Parcela do principal resgatado
  redemptionYield     Decimal? @map("redemption_yield") @db.Decimal(15, 2)     // Parcela de rendimento resgatado
  redemptionTotal     Decimal? @map("redemption_total") @db.Decimal(15, 2)     // Total líquido recebido

  // ── Vínculo contábil ──────────────────────────────────────
  journalEntryId String? @map("journal_entry_id") @db.Uuid
  notes          String? @map("notes") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  investment FixedIncomeInvestment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId, eventDate])
  @@index([companyId, eventType])
  @@map("fixed_income_events")
}

// =============================================================================
// 13 · TABELA CDI DIÁRIO (BCB — Série 12)
// =============================================================================

model CdiDailyRate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @map("date") @db.Date
  dailyRate    Decimal  @map("daily_rate") @db.Decimal(10, 6)
  monthlyAccum Decimal  @map("monthly_accum") @db.Decimal(10, 4)
  yearAccum    Decimal  @map("year_accum") @db.Decimal(10, 4)
  accum30d     Decimal  @map("accum_30d") @db.Decimal(10, 4)
  accum12m     Decimal  @map("accum_12m") @db.Decimal(10, 4)
  accumIndex   Decimal  @map("accum_index") @db.Decimal(18, 7)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([date])
  @@index([date])
  @@map("cdi_daily_rates")
}

// =============================================================================
// 12 · CALENDÁRIO DE FERIADOS
// =============================================================================

enum HolidayType {
  NACIONAL
  ESTADUAL
  MUNICIPAL
  JUDAICO
  FACULTATIVO

  @@map("holiday_type")
}

model Holiday {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date      DateTime    @map("date") @db.Date
  name      String      @map("name") @db.VarChar(100)
  type      HolidayType @map("type")
  state     String?     @map("state") @db.VarChar(2)
  city      String?     @map("city") @db.VarChar(100)
  recurring Boolean     @default(false) @map("recurring")
  // Feriados judaicos
  hebrewName    String? @map("hebrew_name") @db.VarChar(100)
  hebrewDate    String? @map("hebrew_date") @db.VarChar(20)  // ex: "15 Nissan"
  erevStart     Boolean @default(false) @map("erev_start")   // inicia na vespera ao por do sol
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([date, type, state, city])
  @@index([date])
  @@index([type])
  @@map("holidays")
}


// =============================================================================
// PRO-LABORE
// =============================================================================

/// Configuracao de pro-labore por diretor e empresa
model ProLaboreConfig {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  personId  String @map("person_id") @db.Uuid
  cargo     String @map("cargo") @db.VarChar

  valorBruto      Decimal  @map("valor_bruto") @db.Decimal(15,2)
  competenciaIni  String   @map("competencia_ini") @db.VarChar(7) // AAAA-MM
  competenciaFim  String?  @map("competencia_fim") @db.VarChar(7)
  ativo           Boolean  @default(true) @map("ativo")

  // Contas contabeis por empresa
  contaDespesaId    String? @map("conta_despesa_id") @db.Uuid
  contaPassivoId    String? @map("conta_passivo_id") @db.Uuid
  contaInssEmpId    String? @map("conta_inss_emp_id") @db.Uuid
  contaInssDir      String? @map("conta_inss_dir_id") @db.Uuid
  contaIrrfId       String? @map("conta_irrf_id") @db.Uuid
  contaInssRecolherId String? @map("conta_inss_recolher_id") @db.Uuid
  contaIrrfRecolherId String? @map("conta_irrf_recolher_id") @db.Uuid

  documentoId String? @map("documento_id") @db.Uuid  // Ata de reuniao

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)

  company   Company @relation(fields: [companyId], references: [id])
  person    Person  @relation(fields: [personId], references: [id])
  calculos  ProLaboreCalculo[]

  @@index([companyId, personId])
  @@index([companyId, competenciaIni])
  @@map("pro_labore_configs")
}

/// Calculo mensal de pro-labore
model ProLaboreCalculo {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configId   String @map("config_id") @db.Uuid
  companyId  String @map("company_id") @db.Uuid
  competencia String @map("competencia") @db.VarChar(7) // AAAA-MM

  valorBruto      Decimal @map("valor_bruto") @db.Decimal(15,2)
  inssEmpresa     Decimal @map("inss_empresa") @db.Decimal(15,2)   // 20%
  inssDiretor     Decimal @map("inss_diretor") @db.Decimal(15,2)   // 11% (teto)
  baseIrrf        Decimal @map("base_irrf") @db.Decimal(15,2)      // bruto - inss diretor
  irrf            Decimal @map("irrf") @db.Decimal(15,2)
  aliqIrrf        Decimal @map("aliq_irrf") @db.Decimal(5,4)
  deducaoIrrf     Decimal @map("deducao_irrf") @db.Decimal(15,2)
  valorLiquido    Decimal @map("valor_liquido") @db.Decimal(15,2)

  journalEntryId  String? @map("journal_entry_id") @db.Uuid
  geradoEm        DateTime? @map("gerado_em") @db.Timestamp(6)
  createdById     String  @map("created_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  config    ProLaboreConfig @relation(fields: [configId], references: [id])
  company   Company         @relation(fields: [companyId], references: [id])

  @@unique([configId, competencia])
  @@index([companyId, competencia])
  @@map("pro_labore_calculos")
}

