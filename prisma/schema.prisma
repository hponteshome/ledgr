/// LALUR Parte A — Demonstração do Lucro Real e base de cálculo da CSLL.
model EcfPartA {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  code        String   @map("code") @db.VarChar
  description String   @map("description") @db.VarChar
  value       Decimal  @map("value") @db.Decimal(18, 2)
  type        String   @map("type") @db.VarChar
  period      String   @map("period") @db.VarChar
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, period])
  @@map("ecf_part_a")
}

/// LALUR Parte B — Controle de adições e exclusões temporárias do lucro real.
model EcfPartB {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  accountCode String   @map("account_code") @db.VarChar
  description String   @map("description") @db.VarChar
  balance     Decimal  @map("balance") @db.Decimal(18, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, accountCode])
  @@index([companyId])
  @@map("ecf_part_b")
